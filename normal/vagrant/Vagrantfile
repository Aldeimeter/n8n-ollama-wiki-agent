# -*- mode: ruby -*-
# vi: set ft=ruby :

    
# One entry per VM: machine name => hostname, private IP, RAM (MB), vCPUs.
# Note: "wiki.js" is defined as "wikijs" because dots in hostnames are treated
# as FQDN separators and confuse some tooling. Rename if you really want the dot.
require 'yaml'
require 'json'
# vms.yml uses string keys; round-trip through JSON to deep-symbolize them
# (incl. nested forwarded_ports) so opts[:ip] / pf[:guest] resolve.
VMS = JSON.parse(YAML.load_file('vms.yml').to_json, symbolize_names: true) # normal/vagrant/vms.yml

# Build "<ip> <hostname>" lines so every VM can resolve the others by name.
# hostname == the map key (vms.yml has no separate hostname field).
HOSTS_BLOCK = VMS.map { |name, o| "#{o[:ip]} #{name}" }.join('\n')

Vagrant.configure("2") do |config|
  config.vm.box = "bento/ubuntu-24.04"

  VMS.each do |name, opts|
    config.vm.define name do |node|
      node.vm.hostname = name
      node.vm.network "private_network", ip: opts[:ip]

      (opts[:forwarded_ports] || []).each do |pf|
          node.vm.network "forwarded_port", guest: pf[:guest], host: pf[:host], host_ip: "127.0.0.1"
      end

      node.vm.provider "virtualbox" do |vb|
        # Disable the KVM paravirt clock. On AMD-V hosts the default
        # (paravirtprovider "kvm") makes the Ubuntu 24.04 guest's kvmclock
        # drift, causing RCU stalls / hung_task at boot and Guru Meditation
        # crashes. "none" boots reliably; "legacy" is an alternative.
        vb.customize ["modifyvm", :id, "--paravirtprovider", "none"]
        vb.customize ["modifyvm", :id, "--cableconnected1", "on"]
        vb.customize ["modifyvm", :id, "--uart1", "0x3F8", "4"]
        vb.customize ["modifyvm", :id, "--uartmode1", "file", File::NULL]
        vb.name   = "normal-#{name}"
        vb.memory = opts[:memory]
        vb.cpus   = opts[:cpus]
      end

      # Add /etc/hosts entries for the whole stack (idempotent).
      # node.vm.provision "shell", inline:
      #   "grep -q '## vagrant-stack ##' /etc/hosts || " \
      #   "printf '## vagrant-stack ##\\n#{HOSTS_BLOCK}\\n' >> /etc/hosts"


    end
  end
end
